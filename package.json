    "dotenv": "^17.3.1",
    "ethers": "^5.8.0",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.3",
    "motion": "^12.23.24",
    "react": "^19.0.0",
